# ============================================================
# SmartInventory — .gitignore
# ============================================================

# --- Entornos (NUNCA subir al repo) ---
.env
.env.*
.env.local
.env.development.local
.env.test.local
.env.production.local
!.env.example          # sí subir los templates
apps/**/.env
apps/**/.env.*
apps/**/.env.*.local
!apps/**/.env.example
supabase/.env
supabase/.env.*
!supabase/.env.example

# --- Supabase CLI (local) ---
.supabase/

# --- Node / npm / yarn ---
node_modules/
**/node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# --- Next.js / Build Artifacts ---
apps/web/.next/
apps/web/out/
apps/web/.vercel/
.cache/
dist/
build/

# --- Backups / Logs ---
backups/
logs/
*.log
*.sql.gz

# --- macOS ---
.DS_Store
**/.DS_Store
.AppleDouble
.LSOverride
Icon


# --- IDEs ---
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
.idea/
*.suo
*.user
*.swp
*.swo

