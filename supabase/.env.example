# ============================================================
# SmartInventory — Backend / Supabase Edge Functions
# ============================================================
# Crea tu archivo real: cp .env.example .env
# NUNCA subas .env al repositorio.
#
# Este archivo se carga en:
#   - Supabase Edge Functions (local dev): `supabase functions serve`
#   - Supabase Hosted: `supabase secrets set KEY=VALUE`
#   - Docker (Modo B): inyectado al contenedor `functions`
#
# ✅ La Gemini API Key SOLO vive aquí (servidor).
# ❌ NUNCA en apps/web/.env (quedaría expuesta en el bundle del navegador).
# ============================================================

# --- Supabase (local) ---
# Obtenidos con: supabase start → supabase status
SUPABASE_URL=http://localhost:54321
SUPABASE_ANON_KEY=PASTE_SUPABASE_ANON_KEY_HERE
SUPABASE_SERVICE_ROLE_KEY=PASTE_SERVICE_ROLE_KEY_HERE

# --- Gemini (SERVER ONLY) ---
# Obtén tu key en: https://aistudio.google.com/apikey
# AI (Server Side Only)
GEMINI_API_KEY=PASTE_GEMINI_API_KEY_HERE
GEMINI_MODEL=gemini-2.0-flash

GROQ_API_KEY=PASTE_GROQ_API_KEY_HERE
GROQ_VISION_MODEL=llama-3.2-11b-vision-preview

# AI Config
AI_PROVIDER_PRIMARY=gemini
AI_PROVIDER_FALLBACK=groq
